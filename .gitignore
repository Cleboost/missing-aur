.idea/

# Arch build artifacts
**/src/
**/pkg/
*.log
*.sig
*.pkg.tar.*

# Ignore everything inside package dirs by default (generated PKGBUILD, downloaded sources, etc.)
packages/**/*

# Allow app-level dirs and their direct files (manifest.yaml, assets)
!packages/*/
!packages/*/manifest.yaml
!packages/*/*.desktop
!packages/*/*.install
!packages/*/*.patch
!packages/*/*.diff
!packages/*/*.png
!packages/*/*.svg

# Allow generated variant dirs (packages/<app>/<pkgname>/) and their tracked files
!packages/*/*/
!packages/*/*/PKGBUILD
!packages/*/*/.SRCINFO
