.idea/
__pycache__/

# Arch build artifacts
**/src/
**/pkg/
*.log
*.sig
*.pkg.tar.*

# Ignore everything inside package dirs by default
packages/**/*

# Allow app-level dirs and their direct files (manifest.yaml, assets)
!packages/*/
!packages/*/manifest.yaml
!packages/*/*.desktop
!packages/*/*.install
!packages/*/*.patch
!packages/*/*.diff
!packages/*/*.png
!packages/*/*.svg

# Generated variant dirs (packages/<app>/<pkgname>/) are never committed
